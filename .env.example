# ============================================
# DataDrivenFramework - Environment Variables
# ============================================
# Copy this file to .env and modify as needed.
# Environment variables override Config.properties values.

# Browser to use for test execution
# Options: chrome, firefox, edge
browser=chrome

# Run browser in headless mode (no GUI)
# Set to 'true' for CI/CD environments
HEADLESS=false

# (Optional) Override the test site URL
# testsiteurl=http://www.way2automation.com/angularjs-protractor/banking/#/login
